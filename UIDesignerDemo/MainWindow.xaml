<Window x:Class="UIDesignerDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:designer="clr-namespace:BgCommon.UI.Designer.UIConfigurationFramework;assembly=BgCommon.UI.Designer"
        mc:Ignorable="d"
        Title="UI组态框架演示" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 工具栏 -->
        <ToolBar Grid.Row="0" Background="LightGray" Height="40">
            <Button Content="新建" Command="{Binding NewConfigurationCommand}" Margin="5"/>
            <Button Content="打开" Command="{Binding OpenConfigurationCommand}" Margin="5"/>
            <Button Content="保存" Command="{Binding SaveConfigurationCommand}" Margin="5"/>
            <Separator/>
            <Button Content="撤销" Command="{Binding UndoCommand}" Margin="5"/>
            <Button Content="重做" Command="{Binding RedoCommand}" Margin="5"/>
            <Separator/>
            <ComboBox ItemsSource="{Binding ZoomLevels}" 
                      SelectedItem="{Binding CurrentZoomLevel}" 
                      Width="80" Margin="5"/>
        </ToolBar>
        
        <!-- 主内容区域 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>
            
            <!-- 左侧：组件面板 -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 搜索框 -->
                    <TextBox Grid.Row="0" Text="{Binding ComponentSearchText, UpdateSourceTrigger=PropertyChanged}" 
                             Margin="5" Height="25" 
                             TextWrapping="Wrap" TextAlignment="Left"
                             VerticalContentAlignment="Center"
                             PlaceholderText="搜索组件..."/>
                    
                    <!-- 组件列表 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ComponentCategories}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Expander Header="{Binding Category}" IsExpanded="True">
                                        <ItemsControl ItemsSource="{Binding Components}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="LightBlue" Margin="2" Padding="5"
                                                            MouseDown="ComponentItem_MouseDown">
                                                        <TextBlock Text="{Binding DisplayName}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Expander>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
            
            <!-- 中间：设计区域 -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="0,0,1,0">
                <designer:ConfigurationEditor x:Name="ConfigurationEditor"/>
            </Border>
            
            <!-- 右侧：属性面板 -->
            <Border Grid.Column="2" BorderBrush="Gray">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <!-- 组件信息 -->
                    <TextBlock Grid.Row="0" Text="{Binding SelectedComponentName}" 
                               Margin="5" FontWeight="Bold" Background="LightYellow" Padding="5"/>
                    
                    <!-- 属性编辑器 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedComponentProperties}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                        <ContentControl Content="{Binding Editor}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                    
                    <!-- 事件编辑器标题 -->
                    <TextBlock Grid.Row="2" Text="事件" Margin="5" FontWeight="Bold" Background="LightGreen" Padding="5"/>
                    
                    <!-- 事件编辑器 -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding SelectedComponentEvents}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                                        <TextBox Text="{Binding HandlerName}" Margin="0,5,0,0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>